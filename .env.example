# ==============================================================================
# UNISMP - Variables de entorno (PLANTILLA)
# Copia este archivo como ".env" y reemplaza los valores.
# El archivo ".env" esta en .gitignore: NUNCA lo subas al repositorio.
#
# IMPORTANTE: en Vite, SOLO las variables con prefijo VITE_ llegan al navegador.
# Por eso aqui SOLO van claves PUBLICAS. Las claves secretas
# (service_role de Supabase, API secret de Cloudinary) NO van aqui:
# viven en Edge Functions / GitHub Actions.
# ==============================================================================

# --- Supabase (claves publicas) ---
# Panel: Supabase > Project Settings > API
# La URL termina en .supabase.co (NO .com)
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY_PUBLICA

# --- Cloudinary (subida unsigned, datos publicos) ---
# Panel: Cloudinary > Settings > Upload > Upload presets
VITE_CLOUDINARY_CLOUD_NAME=TU_CLOUD_NAME
VITE_CLOUDINARY_UPLOAD_PRESET=unismp_unsigned
